#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "${SCRIPT_DIR}/.." && pwd)"
CONFIG_DIR="${INIAD_GDRIVE_CONFIG_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/iniad-gdrive}"
DEFAULT_DEST=".imports/iniad-gdrive"
GDRIVE_BIN="${INIAD_GDRIVE_GDRIVE_BIN:-gdrive}"
NODE_BIN="${INIAD_GDRIVE_NODE_BIN:-node}"
MYGDRIVE_ENTRY="${INIAD_GDRIVE_MYGDRIVE_ENTRY:-${REPO_ROOT}/vendor/mygdrive/dist/cli.js}"

usage() {
  cat <<'EOF'
Usage:
  iniad-gdrive auth
  iniad-gdrive search <query> [--max N]
  iniad-gdrive import (--id ID | --url URL | --query QUERY) [--dest PATH] [--mime MIME]
  iniad-gdrive browse [folder-id-or-url]

Environment:
  INIAD_GDRIVE_CONFIG_DIR  Override gdrive config dir
  INIAD_GDRIVE_GDRIVE_BIN  Override gdrive binary
  INIAD_GDRIVE_NODE_BIN    Override node binary for browse
  INIAD_GDRIVE_MYGDRIVE_ENTRY Override vendored mygdrive entrypoint
EOF
}

fail() {
  printf '%s\n' "$*" >&2
  exit 1
}

ensure_command() {
  command -v "$1" >/dev/null 2>&1 || fail "Required command not found: $1"
}

run_gdrive() {
  ensure_command "$GDRIVE_BIN"
  "$GDRIVE_BIN" -c "$CONFIG_DIR" "$@"
}

has_auth_config() {
  [ -d "$CONFIG_DIR" ] || return 1
  find "$CONFIG_DIR" -maxdepth 1 -type f \
    \( -name 'token*.json' -o -name 'credentials.json' -o -name 'service-account*.json' \) \
    | grep -q .
}

require_auth() {
  has_auth_config || fail "Authentication required. Run: iniad-gdrive auth"
}

query_with_defaults() {
  printf "trashed = false and (%s)" "$1"
}

info_value() {
  local info="$1"
  local key="$2"
  local line
  while IFS= read -r line; do
    case "$line" in
      "${key}:"*)
        printf '%s\n' "${line#*: }"
        return 0
        ;;
    esac
  done <<EOF
$info
EOF
  return 1
}

extract_url_kind_and_id() {
  local url="$1"

  if [[ "$url" =~ drive\.google\.com/.*/folders/([^/?#]+) ]] || [[ "$url" =~ drive\.google\.com/drive/folders/([^/?#]+) ]]; then
    printf 'folder:%s\n' "${BASH_REMATCH[1]}"
    return 0
  fi

  if [[ "$url" =~ drive\.google\.com/file/d/([^/?#]+) ]]; then
    printf 'file:%s\n' "${BASH_REMATCH[1]}"
    return 0
  fi

  if [[ "$url" =~ docs\.google\.com/document/d/([^/?#]+) ]]; then
    printf 'file:%s\n' "${BASH_REMATCH[1]}"
    return 0
  fi

  if [[ "$url" =~ docs\.google\.com/spreadsheets/d/([^/?#]+) ]]; then
    printf 'file:%s\n' "${BASH_REMATCH[1]}"
    return 0
  fi

  if [[ "$url" =~ docs\.google\.com/presentation/d/([^/?#]+) ]]; then
    printf 'file:%s\n' "${BASH_REMATCH[1]}"
    return 0
  fi

  if [[ "$url" =~ [\?\&]id=([^&/#]+) ]]; then
    printf 'file:%s\n' "${BASH_REMATCH[1]}"
    return 0
  fi

  return 1
}

default_export_mime() {
  case "$1" in
    application/vnd.google-apps.document)
      printf '%s\n' 'text/markdown'
      ;;
    application/vnd.google-apps.spreadsheet)
      printf '%s\n' 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'
      ;;
    application/vnd.google-apps.presentation|application/vnd.google-apps.drawing)
      printf '%s\n' 'application/pdf'
      ;;
    *)
      return 1
      ;;
  esac
}

resolve_query_to_id() {
  local query="$1"
  local output
  local -a lines=()

  output="$(run_gdrive list --query "$(query_with_defaults "$query")" --max 30 --name-width 0 --absolute --no-header)"
  while IFS= read -r line; do
    [ -n "${line//[[:space:]]/}" ] || continue
    lines+=("$line")
  done <<EOF
$output
EOF

  case "${#lines[@]}" in
    0)
      fail "No files matched query: $query"
      ;;
    1)
      printf '%s\n' "${lines[0]%%[[:space:]]*}"
      ;;
    *)
      printf 'Multiple files matched query. Narrow the query or use --id/--url.\n' >&2
      printf '%s\n' "${lines[@]}" >&2
      exit 1
      ;;
  esac
}

move_single_result() {
  local src_dir="$1"
  local dest_dir="$2"
  local -a produced=()
  local final_path

  mkdir -p "$dest_dir"
  while IFS= read -r -d '' path; do
    produced+=("$path")
  done < <(find "$src_dir" -mindepth 1 -maxdepth 1 -print0)

  [ "${#produced[@]}" -eq 1 ] || fail "Expected exactly one imported file, got ${#produced[@]}"

  final_path="${dest_dir}/$(basename "${produced[0]}")"
  rm -rf "$final_path"
  mv "${produced[0]}" "$final_path"
  printf '%s\n' "$final_path"
}

cmd_auth() {
  mkdir -p "$CONFIG_DIR"
  printf 'Starting gdrive auth flow with config dir: %s\n' "$CONFIG_DIR" >&2
  run_gdrive about
}

cmd_search() {
  local max=30
  local query

  [ "$#" -ge 1 ] || fail "search requires a query"
  query="$1"
  shift

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --max)
        [ "$#" -ge 2 ] || fail "--max requires a value"
        max="$2"
        shift 2
        ;;
      *)
        fail "Unknown search option: $1"
        ;;
    esac
  done

  require_auth
  run_gdrive list --query "$(query_with_defaults "$query")" --max "$max" --absolute
}

cmd_import() {
  local source_mode=""
  local source_value=""
  local dest="$DEFAULT_DEST"
  local export_mime=""
  local resolved
  local resolved_kind
  local file_id=""
  local info
  local mime
  local tmpdir
  local final_path

  [ "$#" -gt 0 ] || fail "import requires one of --id, --url, or --query"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --id|--url|--query)
        [ "$#" -ge 2 ] || fail "$1 requires a value"
        [ -z "$source_mode" ] || fail "Use exactly one of --id, --url, or --query"
        source_mode="${1#--}"
        source_value="$2"
        shift 2
        ;;
      --dest)
        [ "$#" -ge 2 ] || fail "--dest requires a value"
        dest="$2"
        shift 2
        ;;
      --mime)
        [ "$#" -ge 2 ] || fail "--mime requires a value"
        export_mime="$2"
        shift 2
        ;;
      *)
        fail "Unknown import option: $1"
        ;;
    esac
  done

  [ -n "$source_mode" ] || fail "Use one of --id, --url, or --query"
  require_auth

  case "$source_mode" in
    id)
      file_id="$source_value"
      ;;
    query)
      file_id="$(resolve_query_to_id "$source_value")"
      ;;
    url)
      resolved="$(extract_url_kind_and_id "$source_value")" || fail "Unsupported Google Drive URL: $source_value"
      resolved_kind="${resolved%%:*}"
      file_id="${resolved#*:}"
      [ "$resolved_kind" != "folder" ] || fail "Folder URLs cannot be imported directly. Use: iniad-gdrive browse <folder-url>"
      ;;
  esac

  info="$(run_gdrive info "$file_id")"
  mime="$(info_value "$info" "Mime")"

  [ "$mime" != "application/vnd.google-apps.folder" ] || fail "Folders cannot be imported directly. Use: iniad-gdrive browse <folder-id-or-url>"

  tmpdir="$(mktemp -d "${TMPDIR:-/tmp}/iniad-gdrive.XXXXXX")"
  trap 'rm -rf "$tmpdir"' RETURN

  case "$mime" in
    application/vnd.google-apps.*)
      if [ -z "$export_mime" ]; then
        export_mime="$(default_export_mime "$mime")" || fail "Unsupported Google Workspace mime type: $mime. Pass --mime explicitly."
      fi
      (
        cd "$tmpdir"
        run_gdrive export --mime "$export_mime" "$file_id" >/dev/null
      )
      ;;
    *)
      run_gdrive download --path "$tmpdir" --no-progress "$file_id" >/dev/null
      ;;
  esac

  final_path="$(move_single_result "$tmpdir" "$dest")"
  trap - RETURN
  rm -rf "$tmpdir"
  printf '%s\n' "$final_path"
}

cmd_browse() {
  local target="${1:-}"
  local resolved
  local kind
  local folder_id=""
  local shim_dir
  local shim_path

  require_auth
  ensure_command "$NODE_BIN"
  [ -f "$MYGDRIVE_ENTRY" ] || fail "Vendored mygdrive entrypoint not found: $MYGDRIVE_ENTRY"
  [ -d "${REPO_ROOT}/node_modules" ] || fail "browse requires npm dependencies. Run: npm install"

  if [ -n "$target" ]; then
    if [[ "$target" =~ ^https?:// ]]; then
      resolved="$(extract_url_kind_and_id "$target")" || fail "Unsupported Google Drive URL: $target"
      kind="${resolved%%:*}"
      folder_id="${resolved#*:}"
      [ "$kind" = "folder" ] || fail "browse expects a folder URL or folder ID"
    else
      folder_id="$target"
    fi
  fi

  shim_dir="$(mktemp -d "${TMPDIR:-/tmp}/iniad-gdrive-shim.XXXXXX")"
  shim_path="${shim_dir}/gdrive"
  printf '#!/usr/bin/env bash\nexec %q -c %q "$@"\n' "$GDRIVE_BIN" "$CONFIG_DIR" >"$shim_path"
  chmod +x "$shim_path"

  if [ -n "$folder_id" ]; then
    PATH="${shim_dir}:$PATH" "$NODE_BIN" "$MYGDRIVE_ENTRY" browse "$folder_id"
  else
    PATH="${shim_dir}:$PATH" "$NODE_BIN" "$MYGDRIVE_ENTRY" browse
  fi
}

main() {
  local command="${1:-}"
  case "$command" in
    auth)
      shift
      cmd_auth "$@"
      ;;
    search)
      shift
      cmd_search "$@"
      ;;
    import)
      shift
      cmd_import "$@"
      ;;
    browse)
      shift
      cmd_browse "$@"
      ;;
    -h|--help|help|"")
      usage
      ;;
    *)
      fail "Unknown command: $command"
      ;;
  esac
}

main "$@"
